+/* -------------------------------------------------- */
+/*  Toast                                             */
+/* -------------------------------------------------- */
+.toast {
+  @apply fixed bottom-6 right-6 z-50 px-6 py-4 rounded-2xl text-sm font-sans font-medium;
+  background: linear-gradient(135deg, #166534, #15803D);
+  color: #fff;
+  box-shadow: 0 8px 32px rgba(22, 101, 52, 0.45);
+  animation: toastIn 0.4s cubic-bezier(0.22, 1, 0.36, 1), toastOut 0.35s ease-in forwards;
+  animation-delay: 0s, 4.5s;
+}
+
+@keyframes toastIn {
+  from { opacity: 0; transform: translateY(24px) scale(0.95); }
+  to   { opacity: 1; transform: translateY(0) scale(1); }
+}
+
+@keyframes toastOut {
+  from { opacity: 1; transform: translateY(0) scale(1); }
+  to   { opacity: 0; transform: translateY(12px) scale(0.97); }
+}
