# Deprecated duplicate — use `.env.example` as the canonical template.
# Kept so old docs/scripts that mention `env.example` still find guidance.

# ── Required for production ──
OPENAI_API_KEY=
DATABASE_URL=
AUTH_SECRET=
NEXT_PUBLIC_URL=http://localhost:3000

# ── Payments ──
PAYMENT_WEBHOOK_SECRET=
WECHAT_PAY_QR_BASE=
ALLOW_MOCK_WECHAT_PAY=
WECHAT_PAY_ENABLED=          # true = show WeChat/wallet UI notes; default off
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# ── Email / OAuth ──
RESEND_API_KEY=
EMAIL_FROM=ClauseCheck <noreply@yourdomain.com>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Supabase Auth — Phone OTP ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: gate POST /api/ai/review-contract
REVIEW_TEST_SECRET=
