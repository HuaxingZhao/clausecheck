# ── Required for production ──
# OpenAI API Key（不填则使用 demo 数据）
OPENAI_API_KEY=

# Postgres — required on Vercel (JSON file fallback is dev-only)
DATABASE_URL=

# Auth — generate with: openssl rand -base64 32
AUTH_SECRET=

# App URL (used for Stripe redirects, magic links)
NEXT_PUBLIC_URL=http://localhost:3000

# ── Stripe ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Legacy payment link (optional; checkout API is preferred)
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# Email (magic link login + report delivery)
RESEND_API_KEY=
EMAIL_FROM=ClauseCheck <noreply@yourdomain.com>

# OAuth sign-in (optional — enable Google / Apple buttons when set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Contents of AuthKey_XXXXX.p8 — use \n for line breaks in .env
APPLE_PRIVATE_KEY=
